{
  "name": "angular-bridge-poc",
  "version": "0.0.1",
  "private": true,
  "description": "Angular Elements PoC — Shadow DOM + postMessage bridge to SFCC",
  "scripts": {
    "build": "ng build --configuration=production",
    "build:cdn": "ng build --configuration=production && node scripts/prepare-cdn.mjs",
    "serve": "ng serve",
    "config:render": "node scripts/render-config.mjs",
    "serve:test": "npm run config:render && npx serve .rendered",
    "deploy:s3": "set -a && . ./.env && set +a && aws s3 sync dist/acme-bridge-poc/browser/ s3://${CDN_BUCKET}/bridge-poc/${npm_package_version}/ --cache-control 'public,max-age=31536000,immutable'",
    "invalidate:cf": "set -a && . ./.env && set +a && aws cloudfront create-invalidation --distribution-id ${CF_DISTRIBUTION_ID} --paths \"/bridge-poc/${npm_package_version}/*\""
  },
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/elements": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@cricut/ds-sfcc-contract": "file:../ds-sfcc-contract",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "typescript": "~5.9.0"
  }
}
